import requests
from rdflib import RDFS, RDF, XSD, Literal, URIRef
from .vivo_namespace import VIVO, VCARD, OBO, BIBO, FOAF, SKOS
from .utility import join_if_not_empty, add_date

# Simplified work type map
work_type_map = {
    "article": BIBO["AcademicArticle"],
    "book-chapter": BIBO["Chapter"],
    "book": BIBO["Book"],
    "dataset": VIVO["Dataset"],
    "dissertation": BIBO["Thesis"],
    "monograph": BIBO["Book"],
    "peer-review": BIBO["Article"],
    "preprint": VIVO["WorkingPaper"],
    "reference-entry": BIBO["DocumentPart"],
    "report": BIBO["Report"],
    "standard": BIBO["Standard"],
    "other": BIBO["Document"]
}

class WorksCrosswalk:
    def __init__(self, identifier_strategy, create_strategy):
        self.identifier_strategy = identifier_strategy
        self.create_strategy = create_strategy

    def crosswalk(self, openalex_profile, person_uri, graph):
        works_api_url = openalex_profile.get("works_api_url")
        if not works_api_url:
            return

        person_surname = None
        openalex_display_name = openalex_profile.get("display_name")
        if openalex_display_name:
            person_surname = openalex_display_name.split(" ")[-1]
            
        cursor = "*"
        fetched = 0
        total_works = openalex_profile.get("works_count", 0)

        # Let's limit to say max 500 to prevent timeouts during testing
        while cursor and fetched < min(total_works, 500):
            url = f"{works_api_url}&per-page=200&cursor={cursor}"
            r = requests.get(url, headers={"Accept": "application/json"})
            if r.status_code == 200:
                data = r.json()
                results = data.get("results", [])
                if not results:
                    break
                for work in results:
                    self.crosswalk_work(work, person_uri, person_surname, graph)
                fetched += len(results)
                cursor = data.get("meta", {}).get("next_cursor")
            else:
                break

    def crosswalk_work(self, work, person_uri, person_surname, graph):
        work_type = work.get("type", "other")
        work_class = work_type_map.get(work_type, BIBO["Document"])
        
        title = work.get("title")
        if not title:
            return
            
        # Construct work uri
        work_uri = self.identifier_strategy.to_uri(work_class, {"name": title})
        graph.add((work_uri, RDF.type, work_class))
        graph.add((work_uri, RDFS.label, Literal(title)))

        # Publication date
        pub_date = work.get("publication_date")
        if pub_date:
            parts = pub_date.split("-")
            year = parts[0]
            month = parts[1] if len(parts) > 1 else None
            day = parts[2] if len(parts) > 2 else None
            date_uri = add_date(year, graph, self.identifier_strategy, month, day)
            if date_uri:
                graph.add((work_uri, VIVO.dateTimeValue, date_uri))

        # Venue (Journal / Book)
        primary_location = work.get("primary_location") or {}
        source = primary_location.get("source") or {}
        venue_name = source.get("display_name")
        if venue_name:
            venue_type = source.get("type")
            venue_class = BIBO.Journal if venue_type == "journal" else BIBO.Collection
            venue_uri = self.identifier_strategy.to_uri(venue_class, {"name": venue_name})
            graph.add((work_uri, VIVO.hasPublicationVenue, venue_uri))
            
            if self.create_strategy.should_create(venue_class, venue_uri):
                graph.add((venue_uri, RDF.type, venue_class))
                graph.add((venue_uri, RDFS.label, Literal(venue_name)))
                issns = source.get("issn") or []
                for issn in issns:
                    graph.add((venue_uri, BIBO.issn, Literal(issn)))
                    
        # Volume & Issue
        volume = work.get("biblio", {}).get("volume")
        if volume:
            graph.add((work_uri, BIBO.volume, Literal(volume)))
        issue = work.get("biblio", {}).get("issue")
        if issue:
            graph.add((work_uri, BIBO.issue, Literal(issue)))
            
        # Pages
        first_page = work.get("biblio", {}).get("first_page")
        if first_page:
            graph.add((work_uri, BIBO.pageStart, Literal(first_page)))
        last_page = work.get("biblio", {}).get("last_page")
        if last_page:
            graph.add((work_uri, BIBO.pageEnd, Literal(last_page)))
            
        # Identifiers (DOI, OpenAlex ID)
        doi = work.get("doi")
        if doi:
            # e.g., "https://doi.org/10.1007/s10916-025-02213-z"
            clean_doi = doi.replace("https://doi.org/", "")
            graph.add((work_uri, BIBO.doi, Literal(clean_doi)))
            self._add_work_url(doi, work_uri, graph)
            
        openalex_id = work.get("id")
        if openalex_id:
            graph.add((work_uri, VIVO.openalexId, URIRef(openalex_id)))
            
        # Authors
        authorships = work.get("authorships", [])
        for authorship in authorships:
            author = authorship.get("author", {})
            # author ID isn't used directly for the person node here unless we resolve it but VIVO typically uses hashed
            display_name = author.get("display_name", "")
            
            name_parts = display_name.split(" ", 1)
            first_name = name_parts[0] if name_parts else None
            surname = name_parts[1] if len(name_parts) > 1 else first_name
            
            # Identify if this is the focal person
            if person_surname and surname and person_surname.lower() in surname.lower():
                contributor_uri = person_uri
            else:
                first_name_str = first_name or ""
                surname_str = surname or ""
                contributor_uri = self.identifier_strategy.to_uri(FOAF.Person, {"first_name": first_name_str, "surname": surname_str})
                if self.create_strategy.should_create(FOAF.Person, contributor_uri):
                    graph.add((contributor_uri, RDF.type, FOAF.Person))
                    graph.add((contributor_uri, RDFS.label, Literal(display_name)))
            
            # Relate authorship
            contributorship_uri = self.identifier_strategy.to_uri(VIVO.Authorship, 
                                                                  {"contributor_uri": contributor_uri, "work_uri": work_uri})
            graph.add((contributorship_uri, RDF.type, VIVO.Authorship))
            graph.add((contributorship_uri, VIVO.relates, work_uri))
            graph.add((contributorship_uri, VIVO.relates, contributor_uri))

    def _add_work_url(self, url, work_uri, graph):
        vcard_uri = self.identifier_strategy.to_uri(VCARD.Kind, {"url": url})
        graph.add((vcard_uri, RDF.type, VCARD.Kind))
        # Has contact info
        graph.add((work_uri, OBO.ARG_2000028, vcard_uri))
        # Url vcard
        vcard_url_uri = self.identifier_strategy.to_uri(VCARD.URL, {"vcard_uri": vcard_uri})
        graph.add((vcard_url_uri, RDF.type, VCARD.URL))
        graph.add((vcard_uri, VCARD.hasURL, vcard_url_uri))
        graph.add((vcard_url_uri, VCARD.url, Literal(url, datatype=XSD.anyURI)))
